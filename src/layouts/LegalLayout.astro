---
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
---

<!doctype html>
<html lang="nl">
  <head>
    <BaseHead title={title} description={description} canonical={canonical} />
  </head>
  <body>
    <!-- Navigation -->
    <header class="nav-sticky fixed top-0 left-0 right-0 z-50">
      <div class="section-container flex items-center justify-between py-4">
        <a href="/" class="flex items-center gap-2" aria-label="Dutch IPTV – terug naar homepage">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M21 7.5V6.375C21 5.754 20.496 5.25 19.875 5.25H4.125C3.504 5.25 3 5.754 3 6.375V17.625C3 18.246 3.504 18.75 4.125 18.75H19.875C20.496 18.75 21 18.246 21 17.625V16.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15 12L10 9.5V14.5L15 12Z" fill="white"/>
            </svg>
          </div>
          <span class="text-white font-bold text-lg tracking-tight">Dutch <span class="text-orange-500">IPTV</span></span>
        </a>
        <a href="/#prijzen" class="btn-primary text-sm py-2.5 px-5">Bestel Nu</a>
      </div>
    </header>

    <!-- Legal Page Layout -->
    <main class="pt-24 pb-20">
      <div class="section-container">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          <!-- Main Content -->
          <article class="lg:col-span-2 legal-content">
            <slot />
          </article>

          <!-- Promo Sidebar -->
          <aside>
            <div class="promo-sidebar sticky top-28">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-xl bg-orange-500/20 border border-orange-500/30 flex items-center justify-center flex-shrink-0">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" fill="#f97316"/>
                  </svg>
                </div>
                <p class="text-white font-semibold text-sm leading-snug">Op zoek naar de<br/>beste IPTV?</p>
              </div>

              <p class="text-slate-300 text-sm leading-relaxed mb-5">
                Dutch IPTV is dé #1 keuze voor iedereen die op zoek is naar de <strong class="text-orange-400">beste iptv</strong> ervaring in Nederland. 10.000+ zenders, HD kwaliteit, en betrouwbare streams.
              </p>

              <ul class="space-y-2.5 mb-5">
                <li class="flex items-center gap-2 text-sm text-slate-300">
                  <svg width="16" height="16" viewBox="0 0 20 20" fill="#22c55e" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  10.000+ Live Zenders
                </li>
                <li class="flex items-center gap-2 text-sm text-slate-300">
                  <svg width="16" height="16" viewBox="0 0 20 20" fill="#22c55e" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Full HD & 4K Kwaliteit
                </li>
                <li class="flex items-center gap-2 text-sm text-slate-300">
                  <svg width="16" height="16" viewBox="0 0 20 20" fill="#22c55e" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  24/7 Klantenservice
                </li>
                <li class="flex items-center gap-2 text-sm text-slate-300">
                  <svg width="16" height="16" viewBox="0 0 20 20" fill="#22c55e" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Gratis Installatie
                </li>
              </ul>

              <a href="/" class="btn-primary w-full text-sm py-3 justify-center block text-center">
                Keer terug naar de homepagina
              </a>

              <p class="text-slate-500 text-xs text-center mt-3">
                Geen contract · Opzeggen wanneer je wilt
              </p>
            </div>
          </aside>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5">
      <div class="section-container py-10">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <a href="/" class="flex items-center gap-2">
            <span class="text-white font-bold">Dutch <span class="text-orange-500">IPTV</span></span>
          </a>
          <nav class="flex flex-wrap gap-4 text-xs text-slate-500">
            <a href="/privacy" class="hover:text-orange-400 transition-colors">Privacybeleid</a>
            <a href="/voorwaarden" class="hover:text-orange-400 transition-colors">Voorwaarden</a>
            <a href="/terugbetaling" class="hover:text-orange-400 transition-colors">Terugbetaling</a>
            <a href="/disclaimer" class="hover:text-orange-400 transition-colors">Disclaimer</a>
            <a href="/cookies" class="hover:text-orange-400 transition-colors">Cookies</a>
          </nav>
          <p class="text-slate-600 text-xs">© {new Date().getFullYear()} Dutch IPTV</p>
        </div>
      </div>
    </footer>

    <!-- WhatsApp Button -->
    <a
      href="https://wa.me/31612345678?text=Hallo%2C%20ik%20heb%20interesse%20in%20Dutch%20IPTV!"
      target="_blank"
      rel="noopener noreferrer"
      class="whatsapp-btn fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full flex items-center justify-center transition-transform hover:scale-110"
      style="background-color: #25D366;"
      aria-label="Neem contact op via WhatsApp"
      title="Chat met ons op WhatsApp"
    >
      <svg width="30" height="30" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
    </a>
  </body>
</html>
