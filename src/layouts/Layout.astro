---
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Dutch IPTV – #1 IPTV Aanbieder in Nederland | Beste IPTV Kopen',
  description = 'Dutch IPTV is de beste IPTV aanbieder in Nederland. Stream 10.000+ zenders, films & series in Full HD en 4K. Probeer nu risicovrij – geen contract!',
  canonical,
} = Astro.props;
---

<!doctype html>
<html lang="nl">
  <head>
    <BaseHead title={title} description={description} canonical={canonical} />
  </head>
  <body>
    <!-- Navigation -->
    <header class="nav-sticky fixed top-0 left-0 right-0 z-50">
      <div class="section-container flex items-center justify-between py-4">
        <a href="/" class="flex items-center gap-2" aria-label="Dutch IPTV – terug naar homepage">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M21 7.5V6.375C21 5.754 20.496 5.25 19.875 5.25H4.125C3.504 5.25 3 5.754 3 6.375V17.625C3 18.246 3.504 18.75 4.125 18.75H19.875C20.496 18.75 21 18.246 21 17.625V16.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15 12L10 9.5V14.5L15 12Z" fill="white"/>
            </svg>
          </div>
          <span class="text-white font-bold text-lg tracking-tight">Dutch <span class="text-orange-500">IPTV</span></span>
        </a>

        <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-300">
          <a href="/#functies" class="hover:text-orange-400 transition-colors">Functies</a>
          <a href="/#prijzen" class="hover:text-orange-400 transition-colors">Prijzen</a>
          <a href="/#referral" class="hover:text-orange-400 transition-colors">Vrienden</a>
          <a href="/#faq" class="hover:text-orange-400 transition-colors">FAQ</a>
          <a href="/contact" class="hover:text-orange-400 transition-colors">Contact</a>
        </nav>

        <a href="#prijzen" class="btn-primary text-sm py-2.5 px-5">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M3 3H5L5.4 5M7 13H17L21 5H5.4M7 13L5.4 5M7 13L4.707 15.293C4.077 15.923 4.523 17 5.414 17H17M17 17C15.895 17 15 17.895 15 19C15 20.105 15.895 21 17 21C18.105 21 19 20.105 19 19C19 17.895 18.105 17 17 17ZM9 19C9 20.105 8.105 21 7 21C5.895 21 5 20.105 5 19C5 17.895 5.895 17 7 17C8.105 17 9 17.895 9 19Z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Bestel Nu
        </a>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5 mt-20">
      <div class="section-container py-14">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
          <!-- Brand -->
          <div class="md:col-span-2">
            <a href="/" class="flex items-center gap-2 mb-4">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M21 7.5V6.375C21 5.754 20.496 5.25 19.875 5.25H4.125C3.504 5.25 3 5.754 3 6.375V17.625C3 18.246 3.504 18.75 4.125 18.75H19.875C20.496 18.75 21 18.246 21 17.625V16.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M15 12L10 9.5V14.5L15 12Z" fill="white"/>
                </svg>
              </div>
              <span class="text-white font-bold text-lg">Dutch <span class="text-orange-500">IPTV</span></span>
            </a>
            <p class="text-slate-400 text-sm leading-relaxed max-w-xs mb-5">
              De <strong class="text-orange-400">beste IPTV</strong> aanbieder in Nederland. Stream alles wat je wilt, wanneer je wilt — in haarscherp HD en 4K.
            </p>
            <!-- Social Icons -->
            <div class="flex items-center gap-3">
              <!-- WhatsApp -->
              <a href="https://wa.me/31612345678" target="_blank" rel="noopener noreferrer" aria-label="Dutch IPTV WhatsApp" class="w-9 h-9 rounded-lg flex items-center justify-center transition-all hover:scale-110" style="background:rgba(37,211,102,0.15); border:1px solid rgba(37,211,102,0.3);">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="#25D366" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              </a>
              <!-- Telegram -->
              <a href="https://t.me/dutchiptv" target="_blank" rel="noopener noreferrer" aria-label="Dutch IPTV Telegram" class="w-9 h-9 rounded-lg flex items-center justify-center transition-all hover:scale-110" style="background:rgba(0,136,204,0.15); border:1px solid rgba(0,136,204,0.3);">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="#0088CC" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
              </a>
              <!-- Email -->
              <a href="mailto:info@dutchiptv.nl" aria-label="Dutch IPTV E-mail" class="w-9 h-9 rounded-lg flex items-center justify-center transition-all hover:scale-110" style="background:rgba(249,115,22,0.15); border:1px solid rgba(249,115,22,0.3);">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </a>
              <!-- Facebook -->
              <a href="https://facebook.com/dutchiptv" target="_blank" rel="noopener noreferrer" aria-label="Dutch IPTV Facebook" class="w-9 h-9 rounded-lg flex items-center justify-center transition-all hover:scale-110" style="background:rgba(24,119,242,0.15); border:1px solid rgba(24,119,242,0.3);">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="#1877F2" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <!-- Instagram -->
              <a href="https://instagram.com/dutchiptv" target="_blank" rel="noopener noreferrer" aria-label="Dutch IPTV Instagram" class="w-9 h-9 rounded-lg flex items-center justify-center transition-all hover:scale-110" style="background:rgba(225,48,108,0.15); border:1px solid rgba(225,48,108,0.3);">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="url(#ig)" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <defs><linearGradient id="ig" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" stop-color="#f09433"/><stop offset="25%" stop-color="#e6683c"/><stop offset="50%" stop-color="#dc2743"/><stop offset="75%" stop-color="#cc2366"/><stop offset="100%" stop-color="#bc1888"/></linearGradient></defs>
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </a>
            </div>

            <p class="text-slate-500 text-xs mt-5">
              © {new Date().getFullYear()} Dutch IPTV. Alle rechten voorbehouden.
            </p>
          </div>

          <!-- Quick Links -->
          <div>
            <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Navigatie</h3>
            <ul class="space-y-2 text-sm text-slate-400">
              <li><a href="/" class="hover:text-orange-400 transition-colors">Home</a></li>
              <li><a href="/#functies" class="hover:text-orange-400 transition-colors">Functies</a></li>
              <li><a href="/#prijzen" class="hover:text-orange-400 transition-colors">Prijzen</a></li>
              <li><a href="/#faq" class="hover:text-orange-400 transition-colors">FAQ</a></li>
              <li><a href="/contact" class="hover:text-orange-400 transition-colors">Contact</a></li>
            </ul>
          </div>

          <!-- Legal Links -->
          <div>
            <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Juridisch</h3>
            <ul class="space-y-2 text-sm text-slate-400">
              <li><a href="/privacy" class="hover:text-orange-400 transition-colors">Privacybeleid</a></li>
              <li><a href="/voorwaarden" class="hover:text-orange-400 transition-colors">Algemene Voorwaarden</a></li>
              <li><a href="/terugbetaling" class="hover:text-orange-400 transition-colors">Terugbetalingsbeleid</a></li>
              <li><a href="/disclaimer" class="hover:text-orange-400 transition-colors">Disclaimer</a></li>
              <li><a href="/cookies" class="hover:text-orange-400 transition-colors">Cookiebeleid</a></li>
            </ul>
          </div>
        </div>
      </div>
    </footer>

    <!-- WhatsApp Sticky Button -->
    <a
      href="https://wa.me/31612345678?text=Hallo%2C%20ik%20heb%20interesse%20in%20Dutch%20IPTV!"
      target="_blank"
      rel="noopener noreferrer"
      id="whatsapp-btn"
      class="whatsapp-btn fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full flex items-center justify-center transition-transform hover:scale-110"
      style="background-color: #25D366;"
      aria-label="Neem contact op via WhatsApp"
      title="Chat met ons op WhatsApp"
    >
      <svg width="30" height="30" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
    </a>
  </body>
</html>
