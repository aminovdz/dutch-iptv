---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical = 'https://dutch-iptv.cc/',
  ogImage = '/dutch-iptv-hero.png',
} = Astro.props;

const siteUrl = 'https://dutch-iptv.cc';
---

<!-- Charset & Viewport -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<!-- Primary Meta -->
<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content="Dutch IPTV, beste iptv, iptv nederland, iptv kopen, iptv abonnement, iptv aanbieder, iptv pakket" />
<meta name="author" content="Dutch IPTV" />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={canonical} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={`${siteUrl}${ogImage}`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="nl_NL" />
<meta property="og:site_name" content="Dutch IPTV" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

<!-- Schema.org Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "Dutch IPTV",
      "url": siteUrl,
      "description": description,
      "areaServed": "NL",
      "availableLanguage": ["nl"]
    },
    {
      "@type": "Product",
      "@id": `${siteUrl}/#product`,
      "name": "Dutch IPTV Abonnement",
      "description": "Premium IPTV service met 10.000+ zenders in Full HD en 4K.",
      "brand": {
        "@type": "Brand",
        "name": "Dutch IPTV"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "1250"
      },
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": "EUR",
        "lowPrice": "8.00",
        "highPrice": "55.00",
        "offerCount": "4",
        "offers": [
          {
            "@type": "Offer",
            "name": "Starter 1 Maand",
            "price": "8.00",
            "priceCurrency": "EUR",
            "url": `${siteUrl}/#prijzen`
          },
          {
            "@type": "Offer",
            "name": "Populair 3 Maanden",
            "price": "20.00",
            "priceCurrency": "EUR",
            "url": `${siteUrl}/#prijzen`
          },
          {
            "@type": "Offer",
            "name": "Slim 6 Maanden",
            "price": "30.00",
            "priceCurrency": "EUR",
            "url": `${siteUrl}/#prijzen`
          },
          {
            "@type": "Offer",
            "name": "Beste Deal 12 Maanden",
            "price": "55.00",
            "priceCurrency": "EUR",
            "url": `${siteUrl}/#prijzen`
          }
        ]
      }
    }
  ]
})} />

<!-- Favicons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<!-- Astro Generator -->
<meta name="generator" content={Astro.generator} />

<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-CSWL88HQ5W"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-CSWL88HQ5W');
</script>

